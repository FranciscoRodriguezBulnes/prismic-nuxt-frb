{"name":"Perfil Francisco-Cobalt2","settings":"{\"settings\":\"{\\r\\n  \\\"editor.defaultFormatter\\\": \\\"esbenp.prettier-vscode\\\",\\r\\n  \\\"editor.formatOnSave\\\": true,\\r\\n  \\\"files.eol\\\": \\\"\\\\n\\\",\\r\\n  \\\"material-ui-snippets.showNotesOnStartup\\\": false,\\r\\n\\r\\n  \\\"github.copilot.enable\\\": {\\r\\n    \\\"*\\\": false,\\r\\n    \\\"plaintext\\\": false,\\r\\n    \\\"markdown\\\": false,\\r\\n    \\\"scminput\\\": false,\\r\\n  },\\r\\n\\r\\n    // --- Barra Menú de Persiana y demás---\\r\\n  \\\"workbench.colorCustomizations\\\": {\\r\\n  \\\"titleBar.activeBackground\\\": \\\"#c87208\\\",\\r\\n  \\\"titleBar.activeForeground\\\": \\\"#ffffff\\\",\\r\\n  \\\"titleBar.inactiveBackground\\\": \\\"#703e02\\\",\\r\\n  \\\"titleBar.inactiveForeground\\\": \\\"#ab640e\\\"\\r\\n},\\r\\n\\r\\n  \\\"editor.semanticHighlighting.enabled\\\": true,\\r\\n  \\\"workbench.iconTheme\\\": \\\"material-icon-theme\\\",\\r\\n  \\\"tailwindCSS.emmetCompletions\\\": true,\\r\\n  \\\"editor.inlineSuggest.enabled\\\": false,\\r\\n  \\\"emmet.triggerExpansionOnTab\\\": true,\\r\\n  \\\"files.autoSave\\\": \\\"afterDelay\\\",\\r\\n\\r\\n  // --- OPTIMIZACIÓN JETBRAINS MONO ---\\r\\n  \\\"editor.fontFamily\\\": \\\"JetBrains Mono, Inter, monospace\\\",\\r\\n  \\\"editor.fontLigatures\\\": true,\\r\\n  \\\"editor.fontSize\\\": 15,\\r\\n  \\\"editor.lineHeight\\\": 1.5,\\r\\n  \\\"editor.letterSpacing\\\": 0.3,\\r\\n\\r\\n  // --- SUAVIDAD Y COMODIDAD ---\\r\\n  \\\"editor.cursorSmoothCaretAnimation\\\": \\\"on\\\",\\r\\n  \\\"editor.smoothScrolling\\\": true,\\r\\n\\r\\n  // --- APARIENCIA LIMPIA ---\\r\\n  \\\"editor.stickyScroll.enabled\\\": true,\\r\\n  \\\"editor.renderWhitespace\\\": \\\"all\\\",\\r\\n  \\\"editor.guides.indentation\\\": true,\\r\\n  \\\"editor.bracketPairColorization.enabled\\\": true,\\r\\n\\r\\n  // --- TERMINAL A JUEGO ---\\r\\n  \\\"terminal.integrated.fontFamily\\\": \\\"JetBrains Mono\\\",\\r\\n  \\\"terminal.integrated.fontLigatures.enabled\\\": true,\\r\\n  \\\"tailwindCSS.classAttributes\\\": [\\r\\n    \\\"class\\\",\\r\\n    \\\"className\\\",\\r\\n    \\\"ngClass\\\",\\r\\n    \\\"class:list\\\",\\r\\n    \\\"nombreClase\\\",\\r\\n  ],\\r\\n  \\\"gitlens.ai.model\\\": \\\"vscode\\\",\\r\\n  \\\"gitlens.ai.vscode.model\\\": \\\"copilot:gpt-4.1\\\",\\r\\n  \\\"workbench.colorTheme\\\": \\\"Cobalt2\\\",\\r\\n}\\r\\n\"}","keybindings":"{\"keybindings\":\"// Coloque sus atajos de teclado en este archivo para sobreescribir los valores predeterminados\\n[\\n  {\\n    \\\"key\\\": \\\"ctrl+m ctrl+m\\\",\\n    \\\"command\\\": \\\"dart.toggleLineComment\\\",\\n  },\\n  {\\n    \\\"key\\\": \\\"ctrl+alt+m\\\",\\n    \\\"command\\\": \\\"editor.action.toggleMinimap\\\",\\n  },\\n]\\n\",\"platform\":3}","snippets":"{\"snippets\":{\"javascript.json\":\"{\\n  \\\"Arrow function\\\": {\\n    \\\"prefix\\\": \\\"aff\\\",\\n    \\\"body\\\": [\\n      \\\"const ${1:name} = (${2:params}) => {\\\",\\n      \\\"  $0\\\",\\n      \\\"}\\\"\\n    ],\\n    \\\"description\\\": \\\"Crea una función flecha\\\"\\n  }\\n}\",\"typescript.json\":\"{\\n  // Place your snippets for typescript here. Each snippet is defined under a snippet name and has a prefix, body and \\n  // description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:\\n  // $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the \\n  // same ids are connected.\\n  // Example:\\n  // \\\"Print to console\\\": {\\n  // \\t\\\"prefix\\\": \\\"log\\\",\\n  // \\t\\\"body\\\": [\\n  // \\t\\t\\\"console.log('$1');\\\",\\n  // \\t\\t\\\"$2\\\"\\n  // \\t],\\n  // \\t\\\"description\\\": \\\"Log output to console\\\"\\n  // }\\n  //\\n  // You can also restrict snippets to specific files using include/exclude patterns:\\n  // \\\"Test snippet\\\": {\\n  // \\t\\\"prefix\\\": \\\"test\\\",\\n  // \\t\\\"body\\\": \\\"test('$1', () => {\\\\n\\\\t$0\\\\n});\\\",\\n  // \\t\\\"include\\\": [\\\"**/*.test.ts\\\", \\\"*.spec.ts\\\"],\\n  // \\t\\\"exclude\\\": [\\\"**/temp/*.ts\\\"],\\n  // \\t\\\"description\\\": \\\"Insert test block\\\"\\n  // }\\n  \\\"Nuxt defineEventHandler\\\": {\\n    \\\"prefix\\\": \\\"deh\\\",\\n    \\\"body\\\": [\\n      \\\"export default defineEventHandler((event) => {\\\",\\n      \\\"  $0\\\",\\n      \\\"});\\\"\\n    ],\\n    \\\"description\\\": \\\"Crea un defineEventHandler con función flecha\\\"\\n  },\\n  \\\"Nuxt defineEventHandler async\\\": {\\n    \\\"prefix\\\": \\\"deha\\\",\\n    \\\"body\\\": [\\n      \\\"export default defineEventHandler(async (event) => {\\\",\\n      \\\"  $0\\\",\\n      \\\"});\\\"\\n    ],\\n    \\\"description\\\": \\\"Crea un defineEventHandler async\\\"\\n  },\\n  \\\"Funcion flecha exportada\\\": {\\n    \\\"prefix\\\": \\\"fnexp\\\",\\n    \\\"body\\\": [\\n      \\\"export const ${1:nombreFuncion} = (${2:parametro}) => {\\\",\\n      \\\"  return {\\\",\\n      \\\"    ${3:retornos}\\\",\\n      \\\"  }\\\",\\n      \\\"}\\\"\\n    ],\\n    \\\"description\\\": \\\"Crea una función flecha exportada con parámetros y retorno en objeto\\\"\\n  },\\n  \\\"Nuxt useFetch\\\": {\\n    \\\"prefix\\\": \\\"uf\\\",\\n    \\\"body\\\": [\\n      \\\"const { data, pending, error } = useFetch('${1:/api/endpoint}', {\\\",\\n      \\\"  method: '${2:GET,POST,PATCH}',\\\",\\n      \\\"  body: $0\\\",\\n      \\\"})\\\"\\n    ],\\n    \\\"description\\\": \\\"Plantilla rápida para useFetch con data, pending y error\\\"\\n  },\\n  \\\"Nuxt $fetch\\\": {\\n    \\\"prefix\\\": \\\"ff\\\",\\n    \\\"body\\\": [\\n      \\\"const ${1:result} = await $fetch('${2:/api/endpoint}', {\\\",\\n      \\\"  method: '${3:GET,POST,PATCH}',\\\",\\n      \\\"  body: $0\\\",\\n      \\\"})\\\"\\n    ],\\n    \\\"description\\\": \\\"Plantilla rápida para $fetch con await\\\"\\n  },\\n}\"}}","extensions":"[{\"identifier\":{\"id\":\"aaron-bond